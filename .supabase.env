# This file contains the SQL function definition for creating a booking with payment in a PostgreSQL database. The function calculates the total amount based on hourly rates from a pricing slab and inserts records into the bookings and payments tables.
create or replace function public.create_booking_with_payment(
  p_customer_name text,
  p_phone text,
  p_start timestamptz,
  p_end timestamptz,
  p_payment_amount numeric,
  p_payment_mode text,
  p_notes text,
  p_created_by uuid
)
returns json
language plpgsql
security definer
as $$
declare
  v_total numeric := 0;
  v_current timestamptz;
  v_rate numeric;
  v_booking_id uuid;
begin

  -- 1. Validate duration
  if p_end <= p_start then
    raise exception 'End time must be greater than start time';
  end if;

  v_current := p_start;

  -- 2. Iterate hour-by-hour
  while v_current < p_end loop

  select rate_per_hour
  into v_rate
  from pricing_slabs
  where (v_current AT TIME ZONE 'Asia/Kolkata')::time >= start_time
    and (v_current AT TIME ZONE 'Asia/Kolkata')::time < end_time
  limit 1;

  if v_rate is null then
    raise exception 'No pricing slab found for time %', v_current;
  end if;

  v_total := v_total + v_rate;

  v_current := v_current + interval '1 hour';

end loop;

  -- 3. Insert booking
  insert into bookings (
    customer_name,
    customer_phone,
    start_datetime,
    end_datetime,
    total_amount,
    booking_status,
    created_by,
    notes
  )
  values (
    p_customer_name,
    p_phone,
    p_start,
    p_end,
    v_total,
    'BOOKED',
    p_created_by,
    p_notes
  )
  returning id into v_booking_id;

  -- 4. Insert payment (append-only)
  if p_payment_amount > 0 then
    insert into payments (
      booking_id,
      amount,
      payment_mode,
      created_by,
      notes
    )
    values (
      v_booking_id,
      p_payment_amount,
      p_payment_mode::payment_mode,
      p_created_by,
      p_notes
    );
  end if;

  return json_build_object(
    'booking_id', v_booking_id,
    'total_amount', v_total
  );

end;
$$;


# this function retrieves bookings for admin view with various filters and pagination. It calculates total paid and due amounts, and provides a summary of the results.


create or replace function public.get_admin_bookings(
  p_from_date date,
  p_to_date date,
  p_search text default null,
  p_booking_status booking_status_enum default null,
  p_payment_status payment_status_enum default null,
  p_page int default 1,
  p_limit int default 10
)
returns json
language plpgsql
as $$
declare
    v_offset int := (p_page - 1) * p_limit;
    v_result json;
begin

with base_filtered as (
    select *
    from bookings b
    where
        b.start_datetime >= p_from_date
        and b.start_datetime < (p_to_date + interval '1 day')

        and (
            p_booking_status is null
            or b.booking_status = p_booking_status::booking_status_enum
        )

        and (
            p_search is null
            or b.customer_name ilike '%' || p_search || '%'
            or b.customer_phone like '%' || p_search || '%'
        )
),

aggregated as (
    select
        b.id,
        b.customer_name,
        b.customer_phone,
        b.start_datetime,
        b.end_datetime,
        b.booking_status,
        b.total_amount,
        coalesce(sum(p.amount), 0) as total_paid
    from base_filtered b
    left join payments p on p.booking_id = b.id
    group by
        b.id,
        b.customer_name,
        b.customer_phone,
        b.start_datetime,
        b.end_datetime,
        b.booking_status,
        b.total_amount
),

derived as (
    select
        *,
        (total_amount - total_paid) as total_due,
        case
            when total_paid >= total_amount then 'FULL_PAID'::payment_status_enum
            when total_paid > 0 then 'PARTIAL_PAID'::payment_status_enum
            else 'UNPAID'::payment_status_enum
        end as payment_status
    from aggregated
),

payment_filtered as (
    select *
    from derived
    where
        p_payment_status is null
        or payment_status = p_payment_status
),

summary as (
    select
        count(*) as total_bookings,
        coalesce(sum(total_amount), 0) as total_revenue,
        coalesce(sum(total_paid), 0) as total_paid,
        coalesce(sum(total_due), 0) as total_outstanding
    from payment_filtered
),

paginated as (
    select *
    from payment_filtered
    order by start_datetime desc
    offset v_offset
    limit p_limit
)

select json_build_object(
    'data', coalesce((select json_agg(paginated) from paginated), '[]'::json),
    'pagination', json_build_object(
        'total', (select total_bookings from summary),
        'page', p_page,
        'limit', p_limit,
        'totalPages',
          case
            when (select total_bookings from summary) = 0 then 0
            else ceil((select total_bookings from summary)::numeric / p_limit)
          end
    ),
    'summary', (select to_json(summary) from summary)
)
into v_result;

return v_result;

end;
$$;


create or replace function get_dashboard_analytics(
  p_from_date date,
  p_to_date date
)
returns json
language plpgsql
stable
as $$
declare
  result json;
begin

  select json_build_object(

    'summary', (
      select json_build_object(
        'totalRevenue', coalesce(sum(b.total_amount),0),
        'totalBookings', count(b.id),
        'totalHours', coalesce(sum(
          extract(epoch from (b.end_datetime - b.start_datetime)) / 3600
        ),0),
        'avgBookingValue', coalesce(avg(b.total_amount),0)
      )
      from bookings b
      where
        b.booking_status != 'CANCELLED'
        and b.start_datetime >= p_from_date
        and b.start_datetime < (p_to_date + interval '1 day')
    ),

    'revenueTrend', (
      select json_agg(t)
      from (
        select
          date(b.start_datetime) as date,
          sum(b.total_amount) as revenue
        from bookings b
        where
          b.booking_status != 'CANCELLED'
          and b.start_datetime >= p_from_date
          and b.start_datetime < (p_to_date + interval '1 day')
        group by date
        order by date
      ) t
    ),

    'bookingTrend', (
      select json_agg(t)
      from (
        select
          date(b.start_datetime) as date,
          count(b.id) as bookings
        from bookings b
        where
          b.booking_status != 'CANCELLED'
          and b.start_datetime >= p_from_date
          and b.start_datetime < (p_to_date + interval '1 day')
        group by date
        order by date
      ) t
    ),

    'hourlyPerformance', (
      select json_agg(t)
      from (
        with hours as (
          select generate_series(6,23) as hour
        ),
        expanded as (
          select
            generate_series(
              date_trunc('hour', b.start_datetime),
              date_trunc('hour', b.end_datetime) - interval '1 hour',
              interval '1 hour'
            ) as slot_hour
          from bookings b
          where
            b.booking_status != 'CANCELLED'
            and b.start_datetime >= p_from_date
            and b.start_datetime < (p_to_date + interval '1 day')
        )
        select
          h.hour,
          count(e.slot_hour) as bookings
        from hours h
        left join expanded e
          on extract(hour from e.slot_hour) = h.hour
        group by h.hour
        order by h.hour
      ) t
    ),

    'paymentModes', (
      select json_agg(t)
      from (
        select
          p.payment_mode,
          sum(p.amount) as amount
        from payments p
        join bookings b on b.id = p.booking_id
        where
          b.booking_status != 'CANCELLED'
          and b.start_datetime >= p_from_date
          and b.start_datetime < (p_to_date + interval '1 day')
        group by p.payment_mode
      ) t
    )

  ) into result;

  return result;

end;
$$;


create or replace function public.add_booking_payment(
  p_booking_id uuid,
  p_amount integer,
  p_payment_mode public.payment_mode
)
returns json
language plpgsql
security definer
as $$
declare
  v_booking record;
  v_total_paid integer;
  v_remaining integer;
  v_payment record;
begin

  -- 1️⃣ Fetch booking
  select *
  into v_booking
  from public.bookings
  where id = p_booking_id;

  if not found then
    raise exception 'Booking not found';
  end if;

  -- 2️⃣ Prevent payment on cancelled booking
  if v_booking.booking_status = 'CANCELLED' then
    raise exception 'Cannot add payment to cancelled booking';
  end if;

  -- 3️⃣ Calculate already paid
  select coalesce(sum(amount), 0)
  into v_total_paid
  from public.payments
  where booking_id = p_booking_id;

  v_remaining := v_booking.total_amount - v_total_paid;

  -- 4️⃣ Prevent overpayment
  if p_amount > v_remaining then
    raise exception 'Payment exceeds remaining amount';
  end if;

  if p_amount <= 0 then
    raise exception 'Invalid payment amount';
  end if;

  -- 5️⃣ Insert payment
  insert into public.payments (
    booking_id,
    amount,
    payment_mode,
    created_by
  )
  values (
    p_booking_id,
    p_amount,
    p_payment_mode,
    auth.uid()
  )
  returning *
  into v_payment;

  -- 6️⃣ Return updated financial summary
  return json_build_object(
    'success', true,
    'payment', v_payment,
    'total_amount', v_booking.total_amount,
    'total_paid', v_total_paid + p_amount,
    'remaining_amount', v_booking.total_amount - (v_total_paid + p_amount)
  );

end;
$$;


CREATE OR REPLACE FUNCTION public.get_admin_booking_detail(
  p_booking_id uuid
)
RETURNS json
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
  v_result json;
BEGIN

  SELECT json_build_object(
    'id', b.id,
    'customer_name', b.customer_name,
    'customer_phone', b.customer_phone,
    'start_datetime', b.start_datetime,
    'end_datetime', b.end_datetime,
    'booking_status', b.booking_status,
    'notes', b.notes,
    'created_at', b.created_at,

    -- Total amount
    'total_amount', b.total_amount,

    -- Total paid
    'total_paid', COALESCE((
        SELECT SUM(p.amount)
        FROM public.payments p
        WHERE p.booking_id = b.id
    ), 0),

    -- Derived payment status
    'payment_status',
    CASE
        WHEN COALESCE((
            SELECT SUM(p.amount)
            FROM public.payments p
            WHERE p.booking_id = b.id
        ), 0) >= b.total_amount THEN 'FULL_PAID'
        WHEN COALESCE((
            SELECT SUM(p.amount)
            FROM public.payments p
            WHERE p.booking_id = b.id
        ), 0) > 0 THEN 'PARTIAL_PAID'
        ELSE 'UNPAID'
    END,

    -- Payment history array
    'payments', COALESCE((
        SELECT json_agg(
          json_build_object(
            'id', p.id,
            'amount', p.amount,
            'payment_mode', p.payment_mode,
            'created_at', p.created_at
          )
          ORDER BY p.created_at DESC
        )
        FROM public.payments p
        WHERE p.booking_id = b.id
    ), '[]'::json)

  )
  INTO v_result
  FROM public.bookings b
  WHERE b.id = p_booking_id;

  RETURN v_result;

END;
$$;