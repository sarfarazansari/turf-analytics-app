# This file contains the SQL function definition for creating a booking with payment in a PostgreSQL database. The function calculates the total amount based on hourly rates from a pricing slab and inserts records into the bookings and payments tables.
create or replace function public.create_booking_with_payment(
  p_customer_name text,
  p_phone text,
  p_start timestamptz,
  p_end timestamptz,
  p_payment_amount numeric,
  p_payment_mode text,
  p_notes text,
  p_created_by uuid
)
returns json
language plpgsql
security definer
as $$
declare
  v_total numeric := 0;
  v_current timestamptz;
  v_rate numeric;
  v_booking_id uuid;
begin

  -- 1. Validate duration
  if p_end <= p_start then
    raise exception 'End time must be greater than start time';
  end if;

  v_current := p_start;

  -- 2. Iterate hour-by-hour
  while v_current < p_end loop

  select rate_per_hour
  into v_rate
  from pricing_slabs
  where (v_current AT TIME ZONE 'Asia/Kolkata')::time >= start_time
    and (v_current AT TIME ZONE 'Asia/Kolkata')::time < end_time
  limit 1;

  if v_rate is null then
    raise exception 'No pricing slab found for time %', v_current;
  end if;

  v_total := v_total + v_rate;

  v_current := v_current + interval '1 hour';

end loop;

  -- 3. Insert booking
  insert into bookings (
    customer_name,
    customer_phone,
    start_datetime,
    end_datetime,
    total_amount,
    booking_status,
    created_by,
    notes
  )
  values (
    p_customer_name,
    p_phone,
    p_start,
    p_end,
    v_total,
    'BOOKED',
    p_created_by,
    p_notes
  )
  returning id into v_booking_id;

  -- 4. Insert payment (append-only)
  if p_payment_amount > 0 then
    insert into payments (
      booking_id,
      amount,
      payment_mode,
      created_by,
      notes
    )
    values (
      v_booking_id,
      p_payment_amount,
      p_payment_mode::payment_mode,
      p_created_by,
      p_notes
    );
  end if;

  return json_build_object(
    'booking_id', v_booking_id,
    'total_amount', v_total
  );

end;
$$;


# this function retrieves bookings for admin view with various filters and pagination. It calculates total paid and due amounts, and provides a summary of the results.


create or replace function public.get_admin_bookings(
  p_from_date date,
  p_to_date date,
  p_search text default null,
  p_booking_status booking_status_enum default null,
  p_payment_status payment_status_enum default null,
  p_page int default 1,
  p_limit int default 10
)
returns json
language plpgsql
as $$
declare
    v_offset int := (p_page - 1) * p_limit;
    v_result json;
begin

with base_filtered as (
    select *
    from bookings b
    where
        b.start_datetime >= p_from_date
        and b.start_datetime < (p_to_date + interval '1 day')

        and (
            p_booking_status is null
            or b.booking_status = p_booking_status::booking_status_enum
        )

        and (
            p_search is null
            or b.customer_name ilike '%' || p_search || '%'
            or b.customer_phone like '%' || p_search || '%'
        )
),

aggregated as (
    select
        b.id,
        b.customer_name,
        b.customer_phone,
        b.start_datetime,
        b.end_datetime,
        b.booking_status,
        b.total_amount,
        coalesce(sum(p.amount), 0) as total_paid
    from base_filtered b
    left join payments p on p.booking_id = b.id
    group by
        b.id,
        b.customer_name,
        b.customer_phone,
        b.start_datetime,
        b.end_datetime,
        b.booking_status,
        b.total_amount
),

derived as (
    select
        *,
        (total_amount - total_paid) as total_due,
        case
            when total_paid >= total_amount then 'FULL_PAID'::payment_status_enum
            when total_paid > 0 then 'PARTIAL_PAID'::payment_status_enum
            else 'UNPAID'::payment_status_enum
        end as payment_status
    from aggregated
),

payment_filtered as (
    select *
    from derived
    where
        p_payment_status is null
        or payment_status = p_payment_status
),

summary as (
    select
        count(*) as total_bookings,
        coalesce(sum(total_amount), 0) as total_revenue,
        coalesce(sum(total_paid), 0) as total_paid,
        coalesce(sum(total_due), 0) as total_outstanding
    from payment_filtered
),

paginated as (
    select *
    from payment_filtered
    order by start_datetime desc
    offset v_offset
    limit p_limit
)

select json_build_object(
    'data', coalesce((select json_agg(paginated) from paginated), '[]'::json),
    'pagination', json_build_object(
        'total', (select total_bookings from summary),
        'page', p_page,
        'limit', p_limit,
        'totalPages',
          case
            when (select total_bookings from summary) = 0 then 0
            else ceil((select total_bookings from summary)::numeric / p_limit)
          end
    ),
    'summary', (select to_json(summary) from summary)
)
into v_result;

return v_result;

end;
$$;